# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/confero
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/confero
MONGO_URI=mongodb://127.0.0.1:27017/confero

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── STUN/TURN (optional — for production NAT traversal) ──
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_credential
